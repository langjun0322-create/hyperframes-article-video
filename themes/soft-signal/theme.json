        }
      }
    ],
    "elements": [
      {
        "id": "paper_grain",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ss-element-paper-grain",
        "best_for": "subtle paper texture on warm scenes"
      },
      {
        "id": "large_blobs",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ss-element-large-blobs",
        "best_for": "soft product intro and lifestyle scenes"
      },
      {
        "id": "soft_arch",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ss-element-soft-arch",
        "best_for": "quote, viewpoint, case study scenes"
      },
      {
        "id": "botanical_silhouette",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ss-element-botanical-silhouette",
        "best_for": "human-centered and personal brand scenes"
      },
      {
        "id": "subtle_grid_blocks",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ss-element-subtle-grid-blocks",
        "best_for": "version update, checklist, comparison scenes"
      }
    ]
  }
}
