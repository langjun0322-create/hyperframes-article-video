        "type": "png",
        "runtime": true,
        "size": "1920x1080",
        "best_for": "case studies, viewpoint scenes, quote scenes, cover-like moments",
        "safe_area_px": {
          "top": 150,
          "right": 320,
          "bottom": 180,
          "left": 390,
          "note": "Keeps text away from the side arch and color fields."
        }
      },
      {
        "id": "signal_blocks",
        "aliases": [
          "signal_lines"
        ],
        "path": "themes/soft-signal/assets/backgrounds/signal-blocks-bg.png",
        "type": "png",
        "runtime": true,
        "size": "1920x1080",
        "best_for": "AI agents, memory, automation, process flow, relationship mapping using layered soft blocks",
        "safe_area_px": {
          "top": 150,
          "right": 390,
          "bottom": 180,
          "left": 390,
          "note": "Keeps content away from layered soft blocks near edges."
        }
      },
      {
        "id": "soft_grid",
        "path": "themes/soft-signal/assets/backgrounds/soft-grid-bg.png",
        "type": "png",
        "runtime": true,
