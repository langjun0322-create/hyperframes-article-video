        "aliases": [
          "bg_blueprint"
        ],
        "path": "themes/tech-signal/assets/backgrounds/blueprint-bg.png",
        "type": "png",
        "runtime": true,
        "size": "1920x1080",
        "best_for": "system architecture, process diagrams, Gateway/Channel structure, and implementation maps",
        "safe_area_px": {
          "top": 170,
          "right": 360,
          "bottom": 170,
          "left": 360,
          "note": "Keeps content away from sparse corner construction marks and preserves a clean center."
        }
      }
    ],
    "elements": [
      {
        "id": "scan_band",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ts-element-scan-band",
        "best_for": "logo, hook, system scan moments"
      },
      {
        "id": "node_cluster",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ts-element-node-cluster",
        "best_for": "AI memory, graph, provider relation scenes"
      },
      {
        "id": "terminal_strip",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ts-element-terminal-strip",
        "best_for": "code log and debugging scenes"
      },
      {
        "id": "blueprint_marks",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ts-element-blueprint-marks",
        "best_for": "architecture and flow scenes"
      },
      {
        "id": "signal_dots",
        "type": "css_layer",
        "runtime": true,
        "css_class": "ts-element-signal-dots",
        "best_for": "light emphasis without random particles"
      }
    ]
  }
}
