{
  "theme": {
    "id": "folk-frequency",
    "name": "Folk Frequency",
    "version": "1.1.0",
    "role": "handcrafted_folk_article_video_template",
    "description": "Complete handcrafted folk poster page system with warm paper, distressed ink, fixed decorative backgrounds, large woodcut-style titles, open poster layouts, and festival-like content blocks."
  },
  "design_tokens": {
    "colors": {
      "paper": "#F6EDE1",
      "paper_warm": "#EBD8B8",
      "ink": "#1E1E1E",
      "indigo": "#233D7A",
      "coral": "#E84B3C",
      "sunflower": "#F2C230",
      "forest": "#2E6B4E",
      "terracotta": "#C65A3A",
      "cream": "#F6EDE1",
      "muted": "#6F6253"
    },
    "typography": {
      "title_family": "'Folk Display', 'Folk CN', Georgia, 'Times New Roman', serif",
      "display_family": "'Folk Display', 'Folk CN', Georgia, 'Times New Roman', serif",
      "body_family": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Noto Sans SC', sans-serif",
      "local_fonts": [
        "themes/folk-frequency/assets/fonts/Rye-Regular.ttf",
        "themes/folk-frequency/assets/fonts/ZCOOLXiaoWei-Regular.ttf"
      ],
      "title_size": 118,
      "subtitle_size": 28,
      "body_size": 23,
      "caption_size": 18
    },
    "layout": {
      "width": 1920,
      "height": 1080,
      "safe_padding_x": 118,
      "safe_padding_y": 92,
      "radius": 22,
      "panel_border": "3px solid #1E1E1E",
      "max_shadow_opacity": 0.2,
      "safe_area_source": "background_presets[].safe_area_px overrides default safe padding for Folk Frequency backgrounds"
    },
    "motion": {
      "enter_duration": 0.58,
      "exit_duration": 0.38,
      "section_transition": 0.72,
      "stagger": 0.08,
      "enter_ease": "back.out(1.18)",
      "exit_ease": "power2.in",
      "paint_ease": "power3.out"
    },
    "avoid": [
      "photorealistic imagery",
      "neon sci-fi HUD",
      "thin corporate cards",
      "dense tiny repeated icon wallpaper",
      "generic beige minimalism",
      "overly ornate borders that cover text",
      "smooth glossy gradients",
      "randomized ornament placement"
    ]
  },
  "background_presets": [
    {
      "id": "floral_fest",
      "css_class": "ff-bg-floral-fest",
      "best_for": "hook page, opening titles, brand/story introductions, warm social first frames",
      "avoid_for": "dense code logs",
      "asset_path": "themes/folk-frequency/assets/backgrounds/floral-fest-bg.png",
      "safe_area_px": {
        "top": 135,
        "right": 150,
        "bottom": 145,
        "left": 150,
        "note": "Clean folk border background: central safe area is intentionally free of fixed cards, image frames, badges, and panels."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    },
    {
      "id": "night_folk",
      "css_class": "ff-bg-night-folk",
      "best_for": "quote cards, strong claims, hero art moments, emotional emphasis",
      "avoid_for": "long body copy",
      "asset_path": "themes/folk-frequency/assets/backgrounds/night-folk-bg.png",
      "safe_area_px": {
        "top": 145,
        "right": 160,
        "bottom": 150,
        "left": 160,
        "note": "Clean indigo-accent folk border background: quote panels and dark blocks must be separate HTML/CSS elements."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    },
    {
      "id": "sunshine_block",
      "css_class": "ff-bg-sunshine-block",
      "best_for": "metrics, positive results, bright proof points, celebratory conclusions",
      "avoid_for": "risk or error scenes",
      "asset_path": "themes/folk-frequency/assets/backgrounds/sunshine-block-bg.png",
      "safe_area_px": {
        "top": 150,
        "right": 165,
        "bottom": 155,
        "left": 165,
        "note": "Clean sunny folk border background: metric stamps and result blocks must be separate HTML/CSS elements."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    },
    {
      "id": "terracotta_print",
      "css_class": "ff-bg-terracotta-print",
      "best_for": "warnings, deltas, before/after comparison, release change notes",
      "avoid_for": "low-energy calm summaries",
      "asset_path": "themes/folk-frequency/assets/backgrounds/terracotta-print-bg.png",
      "safe_area_px": {
        "top": 145,
        "right": 165,
        "bottom": 150,
        "left": 165,
        "note": "Clean terracotta-accent folk border background: comparison panels must be separate HTML/CSS elements."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    },
    {
      "id": "river_waves",
      "css_class": "ff-bg-river-waves",
      "best_for": "workflows, step-by-step processes, migration or journey scenes",
      "avoid_for": "static quote scenes",
      "asset_path": "themes/folk-frequency/assets/backgrounds/river-waves-bg.png",
      "safe_area_px": {
        "top": 145,
        "right": 160,
        "bottom": 205,
        "left": 160,
        "note": "Clean river-trim folk border background: step cards, arrows, and numbered badges must be separate HTML/CSS elements."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    },
    {
      "id": "forest_floor",
      "css_class": "ff-bg-forest-floor",
      "best_for": "summaries, highlighted ideas, story panels, grounded key points",
      "avoid_for": "very dark title cards",
      "asset_path": "themes/folk-frequency/assets/backgrounds/forest-floor-bg.png",
      "safe_area_px": {
        "top": 145,
        "right": 160,
        "bottom": 150,
        "left": 160,
        "note": "Clean botanical folk border background: key-point blocks and summary panels must be separate HTML/CSS elements."
      },
      "safe_area_rule": "All generated text, cards, badges, color blocks, step cards, metric stamps, logo, avatar, CTA controls, and optional illustrations must be rendered by HTML/CSS inside this rectangle."
    }
  ],
  "layout_templates": {
    "hook": [
      {
        "id": "folk-frequency.hook.reference-hook-page",
        "component_class": "ff-poster-copy-layout ff-hook-page",
        "layout_mode": "open_title",
        "best_for": "reference-style Hook Page with large direct-on-paper title, green page badge, red kicker, and optional bottom colored pills; no background-baked hero zone",
        "uses": [
          "headline",
          "subtitle",
          "kicker",
          "chips"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.hook.open-poster-title",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "open_title",
        "best_for": "large title, short promise, and tags placed directly on the poster background without a wrapper card",
        "uses": [
          "headline",
          "subtitle",
          "chips"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.hook.poster-banner",
        "component_class": "ff-hook-layout",
        "layout_mode": "open_title",
        "best_for": "big title, article promise, social poster opening",
        "uses": [
          "headline",
          "subtitle",
          "chips"
        ]
      }
    ],
    "summary": [
      {
        "id": "folk-frequency.summary.body-page-01",
        "component_class": "ff-poster-copy-layout ff-body-page",
        "layout_mode": "structured_cards",
        "best_for": "reference-style Body Page 01 with large headline and HTML-rendered color blocks, quote panel, or bottom category band",
        "uses": [
          "claim",
          "evidence",
          "items",
          "quote"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.summary.open-editorial",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "open_title",
        "best_for": "claim and short evidence list placed on the background with light dividers instead of a full panel",
        "uses": [
          "claim",
          "evidence",
          "proof_points"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.summary.story-panel",
        "component_class": "ff-summary-layout",
        "layout_mode": "structured_cards",
        "best_for": "claim plus evidence in a warm editorial panel",
        "uses": [
          "claim",
          "evidence",
          "proof_chips"
        ]
      }
    ],
    "comparison": [
      {
        "id": "folk-frequency.comparison.twin-posters",
        "component_class": "ff-comparison-layout",
        "layout_mode": "comparison_board",
        "best_for": "before and after, old and new, two-option contrast",
        "uses": [
          "left",
          "right",
          "criteria"
        ]
      }
    ],
    "key_points": [
      {
        "id": "folk-frequency.key_points.body-page-01-blocks",
        "component_class": "ff-poster-copy-layout ff-body-page",
        "layout_mode": "structured_cards",
        "best_for": "3 key points displayed as colored folk poster blocks without a large enclosing card",
        "uses": [
          "items"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.key_points.workshop-highlights",
        "component_class": "ff-key-layout",
        "layout_mode": "structured_cards",
        "best_for": "3-5 memorable highlights with icon accents",
        "uses": [
          "items"
        ]
      }
    ],
    "metrics": [
      {
        "id": "folk-frequency.metrics.open-stamp-grid",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "metric_board",
        "best_for": "metrics as colored stamp blocks placed directly on the poster background",
        "uses": [
          "metrics"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.metrics.open-stamps",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "metric_board",
        "best_for": "numbers displayed as individual stamp tiles without a large enclosing card",
        "uses": [
          "metrics"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.metrics.stamp-tiles",
        "component_class": "ff-metrics-layout",
        "layout_mode": "metric_board",
        "best_for": "numbers, counts, dates, short proof points",
        "uses": [
          "metrics"
        ]
      }
    ],
    "code_log": [
      {
        "id": "folk-frequency.code_log.handbill-console",
        "component_class": "ff-code-layout",
        "layout_mode": "terminal_panel",
        "best_for": "commands and technical strings inside a printable handbill",
        "uses": [
          "entries"
        ]
      }
    ],
    "architecture": [
      {
        "id": "folk-frequency.architecture.process-path",
        "component_class": "ff-arch-layout",
        "layout_mode": "diagram_flow",
        "best_for": "simple flow with named layers and roles",
        "uses": [
          "nodes",
          "links"
        ]
      }
    ],
    "steps": [
      {
        "id": "folk-frequency.steps.body-page-02-flow",
        "component_class": "ff-poster-copy-layout ff-step-page",
        "layout_mode": "structured_cards",
        "best_for": "reference-style Body Page 02 with HTML-rendered step panels, circular numbers, arrows, and optional bottom label strip",
        "uses": [
          "steps"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.steps.open-program-list",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "structured_cards",
        "best_for": "short workflow or checklist placed directly on the background with numbered dividers",
        "uses": [
          "steps"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.steps.event-program",
        "component_class": "ff-steps-layout",
        "layout_mode": "structured_cards",
        "best_for": "sequence, upgrade guide, checklist, process",
        "uses": [
          "steps"
        ]
      }
    ],
    "warning": [
      {
        "id": "folk-frequency.warning.coral-notice",
        "component_class": "ff-warning-layout",
        "layout_mode": "structured_cards",
        "best_for": "constraints, caveats, risk notes with humane tone",
        "uses": [
          "problem",
          "fix",
          "risk_level"
        ]
      }
    ],
    "quote": [
      {
        "id": "folk-frequency.quote.dashed-poster-quote",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "quote_focus",
        "best_for": "quote in a dashed folk poster panel or quiet indigo zone, not a generic glass card",
        "uses": [
          "quote",
          "source",
          "context"
        ],
        "cardless": true
      },
      {
        "id": "folk-frequency.quote.indigo-quote-card",
        "component_class": "ff-quote-layout",
        "layout_mode": "quote_focus",
        "best_for": "short quote or central sentiment",
        "uses": [
          "quote",
          "source",
          "context"
        ]
      }
    ],
    "conclusion": [
      {
        "id": "folk-frequency.conclusion.festival-cta",
        "component_class": "ff-conclusion-layout",
        "layout_mode": "structured_cards",
        "best_for": "final recommendation and follow-through",
        "uses": [
          "action",
          "reason",
          "compatibility",
          "command"
        ]
      },
      {
        "id": "folk-frequency.conclusion.open-title",
        "component_class": "ff-poster-copy-layout",
        "layout_mode": "open_title",
        "best_for": "short closing line printed directly on the poster field",
        "uses": [
          "action",
          "reason"
        ],
        "cardless": true
      }
    ],
    "image_evidence": [
      {
        "id": "folk-frequency.image_evidence.media-focus",
        "component_class": "ff-media-focus-layout",
        "layout_mode": "media_focus",
        "best_for": "a source image framed as a poster photograph",
        "uses": [
          "image_path",
          "alt",
          "caption",
          "why_relevant",
          "source_section"
        ]
      },
      {
        "id": "folk-frequency.image_evidence.split-media-text",
        "component_class": "ff-split-media-layout",
        "layout_mode": "split_media_text",
        "best_for": "a source image with printed annotation and stamp metadata",
        "uses": [
          "image_path",
          "alt",
          "caption",
          "why_relevant",
          "source_section"
        ]
      }
    ]
  },
  "card_templates": {
    "hook": {
      "required_payload": [
        "headline",
        "subtitle"
      ],
      "optional_payload": [
        "version",
        "date",
        "chips"
      ],
      "component_class": "ff-card-hook",
      "layout_templates": [
        "folk-frequency.hook.reference-hook-page",
        "folk-frequency.hook.open-poster-title",
        "folk-frequency.hook.poster-banner"
      ]
    },
    "summary": {
      "required_payload": [
        "claim",
        "evidence"
      ],
      "optional_payload": [
        "proof_chips"
      ],
      "component_class": "ff-card-summary",
      "layout_templates": [
        "folk-frequency.summary.body-page-01",
        "folk-frequency.summary.open-editorial",
        "folk-frequency.summary.story-panel"
      ]
    },
    "key_points": {
      "required_payload": [
        "items"
      ],
      "constraints": {
        "min_items": 3,
        "max_items": 5,
        "item_fields": [
          "title",
          "detail"
        ]
      },
      "component_class": "ff-card-key-points",
      "layout_templates": [
        "folk-frequency.key_points.body-page-01-blocks",
        "folk-frequency.key_points.workshop-highlights"
      ]
    },
    "steps": {
      "required_payload": [
        "steps"
      ],
      "constraints": {
        "min_items": 2,
        "item_fields": [
          "label",
          "action",
          "detail"
        ]
      },
      "component_class": "ff-card-steps",
      "layout_templates": [
        "folk-frequency.steps.body-page-02-flow",
        "folk-frequency.steps.open-program-list",
        "folk-frequency.steps.event-program"
      ]
    },
    "metrics": {
      "required_payload": [
        "metrics"
      ],
      "constraints": {
        "min_items": 1,
        "item_fields": [
          "value",
          "label"
        ]
      },
      "component_class": "ff-card-metrics",
      "layout_templates": [
        "folk-frequency.metrics.open-stamp-grid",
        "folk-frequency.metrics.open-stamps",
        "folk-frequency.metrics.stamp-tiles"
      ]
    },
    "code_log": {
      "required_payload": [
        "entries"
      ],
      "constraints": {
        "min_items": 2,
        "item_fields": [
          "code",
          "label"
        ]
      },
      "component_class": "ff-card-code-log",
      "layout_templates": [
        "folk-frequency.code_log.handbill-console"
      ]
    },
    "architecture": {
      "required_payload": [
        "nodes",
        "links"
      ],
      "constraints": {
        "min_nodes": 3,
        "node_fields": [
          "name",
          "role"
        ]
      },
      "component_class": "ff-card-architecture",
      "layout_templates": [
        "folk-frequency.architecture.process-path"
      ]
    },
    "warning": {
      "required_payload": [
        "problem",
        "fix"
      ],
      "optional_payload": [
        "risk_level"
      ],
      "component_class": "ff-card-warning",
      "layout_templates": [
        "folk-frequency.warning.coral-notice"
      ]
    },
    "quote": {
      "required_payload": [
        "quote",
        "source"
      ],
      "optional_payload": [
        "context"
      ],
      "component_class": "ff-card-quote",
      "layout_templates": [
        "folk-frequency.quote.dashed-poster-quote",
        "folk-frequency.quote.indigo-quote-card"
      ]
    },
    "comparison": {
      "required_payload": [
        "left",
        "right",
        "criteria"
      ],
      "component_class": "ff-card-comparison",
      "layout_templates": [
        "folk-frequency.comparison.twin-posters"
      ]
    },
    "conclusion": {
      "required_payload": [
        "action",
        "reason"
      ],
      "optional_payload": [
        "compatibility",
        "command"
      ],
      "component_class": "ff-card-conclusion",
      "layout_templates": [
        "folk-frequency.conclusion.festival-cta",
        "folk-frequency.conclusion.open-title"
      ]
    },
    "image_evidence": {
      "required_payload": [
        "image_id",
        "image_path",
        "alt",
        "caption",
        "why_relevant",
        "source_section"
      ],
      "component_class": "ff-card-image-evidence",
      "layout_templates": [
        "folk-frequency.image_evidence.media-focus",
        "folk-frequency.image_evidence.split-media-text"
      ]
    }
  },
  "animation_map": {
    "hook": "poster_reveal",
    "summary": "paint_wipe",
    "key_points": "ornament_bloom",
    "steps": "program_step_stamp",
    "metrics": "stamp_pop",
    "code_log": "handbill_type",
    "architecture": "process_path_reveal",
    "warning": "coral_notice_snap",
    "quote": "indigo_quote_focus",
    "comparison": "twin_poster_compare",
    "conclusion": "festival_cta_settle",
    "image_evidence": "poster_image_reveal"
  },
